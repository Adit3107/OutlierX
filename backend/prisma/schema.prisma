datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Role {
  OWNER
  ADMIN
  ANALYST
  MEMBER
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  INVITED
  SUSPENDED
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELLED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum UploadStatus {
  UPLOADING
  UPLOADED
  PARSING
  PROCESSING
  COMPLETED
  FAILED
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RuleCategory {
  AMOUNT
  LOCATION
  MERCHANT
  TIME
  ACCOUNT
  DEVICE
  CUSTOM
}

enum ConditionOperator {
  EQ
  NEQ
  GT
  GTE
  LT
  LTE
  CONTAINS
  NOT_CONTAINS
  IN
  NOT_IN
  EXISTS
  MISSING
  BETWEEN
}

enum LogicalOperator {
  AND
  OR
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RuleExecutionSource {
  UPLOAD
  MANUAL
  PLAYGROUND
}

enum ActivityEntity {
  USER
  ORGANIZATION
  MEMBERSHIP
  API_KEY
  UPLOAD
  TRANSACTION
  RULE
  ALERT
  SYSTEM
}

model User {
  id                    String        @id @default(uuid())
  clerkUserId           String        @unique
  email                 String        @unique
  firstName             String?
  lastName              String?
  avatar                String?
  status                UserStatus    @default(ACTIVE)
  currentOrganizationId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  currentOrganization Organization? @relation("CurrentOrganization", fields: [currentOrganizationId], references: [id], onDelete: SetNull)
  memberships         Membership[]
  uploads             Upload[]
  apiKeys             ApiKey[]
  alerts              Alert[]
  activityLogs        ActivityLog[]
  createdRules        Rule[]

  @@index([email])
  @@index([clerkUserId])
  @@index([currentOrganizationId])
  @@index([status])
  @@index([createdAt])
}

model Organization {
  id                 String             @id @default(uuid())
  name               String
  slug               String             @unique
  logo               String?
  industry           String?
  website            String?
  subscriptionPlan   SubscriptionPlan   @default(FREE)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  maxUsers           Int                @default(5)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  currentUsers User[]        @relation("CurrentOrganization")
  memberships  Membership[]
  uploads      Upload[]
  transactions Transaction[]
  apiKeys      ApiKey[]
  alerts       Alert[]
  rules        Rule[]
  ruleExecutions RuleExecution[]
  mlPredictions MlPrediction[]
  activityLogs ActivityLog[]

  @@index([subscriptionPlan])
  @@index([subscriptionStatus])
  @@index([createdAt])
}

model Membership {
  id             String           @id @default(uuid())
  organizationId String
  userId         String
  role           Role             @default(MEMBER)
  status         MembershipStatus @default(ACTIVE)
  joinedAt       DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@index([organizationId, role])
}

model ApiKey {
  id             String       @id @default(uuid())
  organizationId String
  createdById    String?
  name           String
  keyHash        String       @unique
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  status         ApiKeyStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
  @@index([organizationId, status])
}

model Upload {
  id               String       @id @default(uuid())
  organizationId   String
  uploadedById     String       @map("uploadedBy")
  filename         String
  originalFilename String
  storageKey       String
  storageUrl       String
  mimeType         String
  fileSize         Int
  fileHash         String
  status           UploadStatus @default(UPLOADING)
  totalRows        Int          @default(0)
  processedRows    Int          @default(0)
  failedRows       Int          @default(0)
  processingTime   Int?
  errorSummary     Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@unique([organizationId, fileHash])
  @@index([organizationId])
  @@index([uploadedById])
  @@index([status])
  @@index([createdAt])
  @@index([organizationId, status])
}

model Transaction {
  id               String   @id @default(uuid())
  organizationId   String
  uploadId         String
  transactionId    String
  timestamp        DateTime
  amount           Decimal  @db.Decimal(18, 2)
  currency         String
  merchant         String
  merchantCategory String?
  accountNumber    String?
  country          String?
  city             String?
  paymentMethod    String?
  description      String?
  referenceNumber  String?
  customerId       String?
  status           String   @default("IMPORTED")
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  upload       Upload       @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  ruleExecutions RuleExecution[]
  mlPrediction MlPrediction?

  @@index([organizationId])
  @@index([transactionId])
  @@index([timestamp])
  @@index([merchant])
  @@index([country])
  @@index([amount])
  @@index([uploadId])
  @@index([organizationId, timestamp])
  @@index([organizationId, createdAt])
  @@index([organizationId, merchant])
  @@index([organizationId, country])
  @@index([organizationId, currency])
  @@index([organizationId, status])
}

model MlPrediction {
  id              String   @id @default(uuid())
  organizationId  String
  transactionId   String   @unique
  mlScore         Float
  mlPrediction    String
  confidence      Float
  modelVersion    String
  processedAt     DateTime
  processingTime  Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction  Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([transactionId])
  @@index([mlPrediction])
  @@index([modelVersion])
  @@index([processedAt])
  @@index([organizationId, processedAt])
}

model Rule {
  id             String        @id @default(uuid())
  organizationId String
  name           String
  description    String?
  category       RuleCategory
  severity       AlertSeverity
  enabled        Boolean       @default(true)
  priority       Int
  weight         Int
  createdBy      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User?        @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  groups       RuleGroup[]
  conditions   RuleCondition[]
  results      RuleResult[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([createdBy])
  @@index([category])
  @@index([severity])
  @@index([enabled])
  @@index([priority])
  @@index([updatedAt])
  @@index([organizationId, enabled, priority])
}

model RuleGroup {
  id             String          @id @default(uuid())
  ruleId         String
  parentGroupId  String?
  operator       LogicalOperator @default(AND)
  position       Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  rule         Rule            @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  parentGroup  RuleGroup?      @relation("NestedRuleGroups", fields: [parentGroupId], references: [id], onDelete: Cascade)
  childGroups  RuleGroup[]     @relation("NestedRuleGroups")
  conditions   RuleCondition[]

  @@index([ruleId])
  @@index([parentGroupId])
  @@index([ruleId, parentGroupId])
}

model RuleCondition {
  id        String            @id @default(uuid())
  ruleId    String
  groupId   String
  field     String
  operator  ConditionOperator
  value     Json?
  dataType  String
  position  Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  rule  Rule      @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  group RuleGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([groupId])
  @@index([field])
  @@index([ruleId, groupId])
}

model RuleExecution {
  id              String              @id @default(uuid())
  organizationId  String
  transactionId   String?
  source          RuleExecutionSource
  finalScore      Int
  riskLevel       RiskLevel
  executionTimeMs Int
  triggeredCount  Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction  Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  results      RuleResult[]

  @@index([organizationId])
  @@index([transactionId])
  @@index([source])
  @@index([riskLevel])
  @@index([createdAt])
  @@index([organizationId, createdAt])
}

model RuleResult {
  id          String        @id @default(uuid())
  executionId String
  ruleId      String
  matched     Boolean
  score       Int
  explanation String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  execution RuleExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  rule      Rule          @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([ruleId])
  @@index([matched])
  @@index([createdAt])
}

model Alert {
  id             String        @id @default(uuid())
  organizationId String
  userId         String?
  severity       AlertSeverity
  title          String
  description    String?
  isRead         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([severity])
  @@index([isRead])
  @@index([createdAt])
  @@index([organizationId, severity])
}

model ActivityLog {
  id             String         @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  entity         ActivityEntity
  entityId       String?
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@index([organizationId, createdAt])
}
