datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Role {
  OWNER
  ADMIN
  ANALYST
  MEMBER
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  INVITED
  SUSPENDED
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELLED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum UploadStatus {
  UPLOADING
  UPLOADED
  FAILED
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActivityEntity {
  USER
  ORGANIZATION
  MEMBERSHIP
  API_KEY
  UPLOAD
  ALERT
  SYSTEM
}

model User {
  id                    String        @id @default(uuid())
  clerkUserId           String        @unique
  email                 String        @unique
  firstName             String?
  lastName              String?
  avatar                String?
  status                UserStatus    @default(ACTIVE)
  currentOrganizationId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  currentOrganization Organization? @relation("CurrentOrganization", fields: [currentOrganizationId], references: [id], onDelete: SetNull)
  memberships         Membership[]
  uploads             Upload[]
  apiKeys             ApiKey[]
  alerts              Alert[]
  activityLogs        ActivityLog[]

  @@index([email])
  @@index([clerkUserId])
  @@index([currentOrganizationId])
  @@index([status])
  @@index([createdAt])
}

model Organization {
  id                 String             @id @default(uuid())
  name               String
  slug               String             @unique
  logo               String?
  industry           String?
  website            String?
  subscriptionPlan   SubscriptionPlan   @default(FREE)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  maxUsers           Int                @default(5)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  currentUsers User[]        @relation("CurrentOrganization")
  memberships  Membership[]
  uploads      Upload[]
  apiKeys      ApiKey[]
  alerts       Alert[]
  activityLogs ActivityLog[]

  @@index([subscriptionPlan])
  @@index([subscriptionStatus])
  @@index([createdAt])
}

model Membership {
  id             String           @id @default(uuid())
  organizationId String
  userId         String
  role           Role             @default(MEMBER)
  status         MembershipStatus @default(ACTIVE)
  joinedAt       DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@index([organizationId, role])
}

model ApiKey {
  id             String       @id @default(uuid())
  organizationId String
  createdById    String?
  name           String
  keyHash        String       @unique
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  status         ApiKeyStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
  @@index([organizationId, status])
}

model Upload {
  id               String           @id @default(uuid())
  organizationId   String
  uploadedById     String           @map("uploadedBy")
  filename         String
  storageUrl       String
  status           UploadStatus     @default(UPLOADING)
  processingStatus ProcessingStatus @default(PENDING)
  totalRecords     Int              @default(0)
  processedRecords Int              @default(0)
  failedRecords    Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([uploadedById])
  @@index([status])
  @@index([processingStatus])
  @@index([createdAt])
  @@index([organizationId, status])
}

model Alert {
  id             String        @id @default(uuid())
  organizationId String
  userId         String?
  severity       AlertSeverity
  title          String
  description    String?
  isRead         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([severity])
  @@index([isRead])
  @@index([createdAt])
  @@index([organizationId, severity])
}

model ActivityLog {
  id             String         @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  entity         ActivityEntity
  entityId       String?
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@index([organizationId, createdAt])
}
